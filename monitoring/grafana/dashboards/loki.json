{
  "title": "Core — Loki",
  "uid": "core-loki",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "allValue": ".*",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All",   "value": "$__all", "selected": true },
          { "text": "info",  "value": "info" },
          { "text": "warn",  "value": "warn" },
          { "text": "error", "value": "error" },
          { "text": "debug", "value": "debug" }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({app=\"core\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"core\", level=\"error\"}[1m]))",
          "legendFormat": "errors/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "Warn Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"core\", level=\"warn\"}[1m]))",
          "legendFormat": "warns/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } }
      }
    },
    {
      "id": 4,
      "title": "Log Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"core\", level=~\"$level\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      }
    }
  ]
}
